    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/websockets": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.0.1",
    "@nestjs/bullmq": "^11.0.1",
    "bullmq": "^5.8.0",
    "@prisma/client": "^6.3.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.5",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",

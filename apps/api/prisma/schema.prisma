// apps/api/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  DELETED
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

enum WorkspaceStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum PhoneNumberType {
  LOCAL
  TOLL_FREE
  MOBILE
}

enum PhoneNumberStatus {
  ACTIVE
  PORTING
  SUSPENDED
  RELEASED
}

enum RingStrategy {
  SIMULTANEOUS
  SEQUENTIAL
  ROUND_ROBIN
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum CallStatus {
  INITIATED
  RINGING
  ANSWERED
  COMPLETED
  MISSED
  VOICEMAIL
  FAILED
  CANCELLED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  QUEUED
  SENDING
  SENT
  DELIVERED
  READ
  FAILED
  UNDELIVERED
}

enum MessageType {
  SMS
  MMS
}

enum TelephonyProvider {
  TELNYX
  TWILIO
}

// ─────────────────────────────────────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email           String      @unique @db.VarChar(320)
  passwordHash    String      @map("password_hash") @db.VarChar(255)
  firstName       String      @map("first_name") @db.VarChar(100)
  lastName        String      @map("last_name") @db.VarChar(100)
  status          UserStatus  @default(ACTIVE) // For MVP, default to ACTIVE directly
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  deletedAt       DateTime?   @map("deleted_at")

  // Relations
  workspaceMembers WorkspaceMember[]
  refreshTokens    RefreshToken[]

  @@index([email])
  @@index([status])
  @@map("users")
}

model RefreshToken {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  tokenHash   String    @unique @map("token_hash") @db.VarChar(255)
  family      String    @db.Uuid
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model Workspace {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String            @db.VarChar(255)
  slug              String            @unique @db.VarChar(100)
  status            WorkspaceStatus   @default(ACTIVE)
  timezone          String            @default("UTC") @db.VarChar(100)
  telephonyProvider TelephonyProvider @default(TELNYX) @map("telephony_provider")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  deletedAt         DateTime?         @map("deleted_at")

  // Relations
  members        WorkspaceMember[]
  phoneNumbers   PhoneNumber[]
  conversations  Conversation[]
  callLogs       CallLog[]
  providerConfig WorkspaceProviderConfig?

  @@index([slug])
  @@index([status])
  @@map("workspaces")
}

model WorkspaceProviderConfig {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String            @unique @map("workspace_id") @db.Uuid
  provider    TelephonyProvider

  // Telnyx credentials & resource mapping
  telnyxApiKey             String? @map("telnyx_api_key") @db.VarChar(512)
  telnyxMessagingProfileId String? @map("telnyx_messaging_profile_id") @db.VarChar(255)
  telnyxConnectionId       String? @map("telnyx_connection_id") @db.VarChar(255)
  telnyxAppId              String? @map("telnyx_app_id") @db.VarChar(255)
  telnyxSipCredentialId    String? @map("telnyx_sip_credential_id") @db.VarChar(255)

  // Twilio credentials & resource mapping
  twilioAccountSid          String? @map("twilio_account_sid") @db.VarChar(255)
  twilioAuthToken           String? @map("twilio_auth_token") @db.VarChar(512)
  twilioMessagingServiceSid String? @map("twilio_messaging_service_sid") @db.VarChar(255)
  twilioTwimlAppSid         String? @map("twilio_twiml_app_sid") @db.VarChar(255)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("workspace_provider_configs")
}

model WorkspaceMember {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId String        @map("workspace_id") @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  role        WorkspaceRole @default(MEMBER)
  displayName String?       @map("display_name") @db.VarChar(255)
  isAvailable Boolean       @default(true) @map("is_available")
  joinedAt    DateTime      @default(now()) @map("joined_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  phoneNumberAssignments PhoneNumberAssignment[]

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
  @@map("workspace_members")
}

model PhoneNumber {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId       String            @map("workspace_id") @db.Uuid
  number            String            @db.VarChar(20) // E.164
  friendlyName      String?           @map("friendly_name") @db.VarChar(255)
  type              PhoneNumberType
  status            PhoneNumberStatus @default(ACTIVE)
  countryCode       String            @map("country_code") @db.VarChar(2)
  areaCode          String?           @map("area_code") @db.VarChar(10)
  ringStrategy      RingStrategy      @default(SIMULTANEOUS) @map("ring_strategy")
  ringTimeout       Int               @default(30) @map("ring_timeout")
  capabilities      Json              @default("{}") @db.JsonB

  // Provider details
  provider         TelephonyProvider @map("provider")
  providerNumberId String?           @unique @map("provider_number_id") @db.VarChar(255)
  providerOrderId  String?           @map("provider_order_id") @db.VarChar(255)

  monthlyRenewsAt   DateTime?         @map("monthly_renews_at")
  releasedAt        DateTime?         @map("released_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workspace   Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignments PhoneNumberAssignment[]
  callLogs    CallLog[]
  conversations Conversation[]

  @@unique([workspaceId, number])
  @@index([workspaceId])
  @@index([number])
  @@index([providerNumberId])
  @@map("phone_numbers")
}

model PhoneNumberAssignment {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phoneNumberId String   @map("phone_number_id") @db.Uuid
  memberId      String   @map("member_id") @db.Uuid
  priority      Int      @default(0)
  assignedAt    DateTime @default(now()) @map("assigned_at")

  phoneNumber PhoneNumber     @relation(fields: [phoneNumberId], references: [id], onDelete: Cascade)
  member      WorkspaceMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([phoneNumberId, memberId])
  @@index([phoneNumberId])
  @@index([memberId])
  @@map("phone_number_assignments")
}

model CallLog {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId     String        @map("workspace_id") @db.Uuid
  phoneNumberId   String        @map("phone_number_id") @db.Uuid
  direction       CallDirection
  status          CallStatus    @default(INITIATED)
  fromNumber      String        @map("from_number") @db.VarChar(20)
  toNumber        String        @map("to_number") @db.VarChar(20)
  answeredById    String?       @map("answered_by_id") @db.Uuid

  startedAt       DateTime      @default(now()) @map("started_at")
  answeredAt      DateTime?     @map("answered_at")
  endedAt         DateTime?     @map("ended_at")
  durationSeconds Int?          @map("duration_seconds")
  
  // Provider-specific details
  providerCallId  String?       @unique @map("provider_call_id") @db.VarChar(255)
  costMicrodollars BigInt       @default(0) @map("cost_microdollars")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workspace   Workspace   @relation(fields: [workspaceId], references: [id])
  phoneNumber PhoneNumber @relation(fields: [phoneNumberId], references: [id])

  @@index([workspaceId])
  @@index([workspaceId, startedAt(sort: Desc)])
  @@index([providerCallId])
  @@map("call_logs")
}

model Conversation {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId     String    @map("workspace_id") @db.Uuid
  phoneNumberId   String    @map("phone_number_id") @db.Uuid
  externalNumber  String    @map("external_number") @db.VarChar(20)
  unreadCount     Int       @default(0) @map("unread_count")
  lastMessageAt   DateTime? @map("last_message_at")
  lastMessageBody String?   @map("last_message_body") @db.VarChar(500)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  phoneNumber PhoneNumber @relation(fields: [phoneNumberId], references: [id])
  messages    Message[]

  @@unique([workspaceId, phoneNumberId, externalNumber])
  @@index([workspaceId])
  @@index([workspaceId, lastMessageAt(sort: Desc)])
  @@map("conversations")
}

model Message {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  workspaceId     String           @map("workspace_id") @db.Uuid
  conversationId  String           @map("conversation_id") @db.Uuid
  direction       MessageDirection
  type            MessageType      @default(SMS)
  status          MessageStatus    @default(QUEUED)
  fromNumber      String           @map("from_number") @db.VarChar(20)
  toNumber        String           @map("to_number") @db.VarChar(20)
  body            String?          @db.Text
  sentById        String?          @map("sent_by_id") @db.Uuid

  // Provider details
  providerMessageId String?        @unique @map("provider_message_id") @db.VarChar(255)
  costMicrodollars  BigInt         @default(0) @map("cost_microdollars")

  sentAt          DateTime?        @map("sent_at")
  deliveredAt     DateTime?        @map("delivered_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([conversationId, createdAt(sort: Desc)])
  @@index([providerMessageId])
  @@map("messages")
}
